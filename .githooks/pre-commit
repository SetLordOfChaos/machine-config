#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "==> Running repo checks"

# Shell scripts
if find scripts -type f -name '*.sh' | grep -q .; then
  echo "==> ShellCheck"
  find scripts -type f -name '*.sh' -print0 | xargs -0 shellcheck
fi

# Nix formatting
echo "==> Checking Nix formatting with alejandra"
# alejandra --check .

# Nix linting
echo "==> Running statix"
# statix check .

echo "==> All checks passed"