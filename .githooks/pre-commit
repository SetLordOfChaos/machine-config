#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "==> Running repo checks (via devShell)"

cd "$REPO_ROOT/nix"

nix develop --command bash -c '
  set -u

  failed=0
  formatting_changed=0

  echo "==> Auto-formatting Nix files with alejandra"
  alejandra .

  if ! git -C .. diff --quiet -- .; then
    formatting_changed=1
  fi

  echo
  echo "==> ShellCheck"
  if ! find ../state ../bootstrap -type f -name "*.sh" -print0 | xargs -0 shellcheck; then
    failed=1
  fi

  echo
  echo "==> Running statix"
  if ! statix check .; then
    failed=1
  fi

  echo
  if [ "$formatting_changed" -ne 0 ]; then
    echo "⚠️  Nix files were auto-formatted by alejandra."
    echo "Please review and re-stage your changes, then commit again."
    exit 1
  fi

  if [ "$failed" -ne 0 ]; then
    echo "❌ One or more checks failed"
    exit 1
  fi

  echo "✅ All checks passed"
'